# ════════════════════════════════════════════════════
# NEXTOKEN CAPITAL — Environment Variables
# ════════════════════════════════════════════════════

# ─── EXISTING (keep your current values) ─────────
MONGODB_URI=your_mongodb_atlas_uri
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=https://nextokencapital.com

# ─── POLYGON / BLOCKCHAIN ────────────────────────
POLYGON_RPC=https://polygon-rpc.com
NEXT_PUBLIC_POLYGON_RPC=https://polygon-rpc.com
ADMIN_PRIVATE_KEY=your_admin_wallet_private_key
TREASURY_WALLET=your_treasury_wallet_address
TREASURY_IBAN=LTxxxxxxxxxxxxxxxxxx

# ─── ESCROW CONTRACT ─────────────────────────────
ESCROW_CONTRACT_ADDRESS=deployed_contract_address_here
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=same_address_here

# ─── MONERIUM ────────────────────────────────────
MONERIUM_CLIENT_ID=your_monerium_client_id
MONERIUM_CLIENT_SECRET=your_monerium_client_secret
MONERIUM_ENV=sandbox
MONERIUM_REDIRECT_URI=https://nextokencapital.com/api/auth/monerium/callback

# ─── POLYGONSCAN (for contract verification) ─────
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ─── CRON (for auto EURe redemption) ─────────────
CRON_SECRET=generate_a_random_secret_here
